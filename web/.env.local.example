# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's gitignored.
#
# Both vars below are shipped to the BROWSER (Vite inlines VITE_* at build
# time). VITE_ALGOLIA_SEARCH_API_KEY MUST be a search-only key scoped to the
# ACS_SPECTRUM_MULTI index — never the admin key.

VITE_ALGOLIA_APP_ID=0EXRPAXB56
VITE_ALGOLIA_SEARCH_API_KEY=your-search-only-key-here
